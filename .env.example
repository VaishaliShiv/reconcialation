# ── Copy to .env and fill real values. NEVER commit .env ──

# Cosmos DB (file side — Yasa's container)
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=reconciliation
COSMOS_FILE_CONTAINER=bank_files
COSMOS_SAP_CONTAINER=bank-sap-source
COSMOS_REGISTRY_CONTAINER=template_registry
COSMOS_EVIDENCE_CONTAINER=evidence
COSMOS_RESULTS_CONTAINER=recon_results

# SAP side: read from Cosmos container now; switch to SAP team's API later
# SAP_READ_MODE: cosmos | api
SAP_READ_MODE=cosmos
SAP_API_BASE=
SAP_API_TOKEN=

# Run mode: cosmos (live) | fixture (local JSON offline test)
SOURCE_MODE=cosmos

# Cosmos write-back defaults. When true, `python run_cosmos_workflow.py VENDOR` writes
# by itself (no --write-sap/--write-summary flag needed). Keep false in test; set true in
# the production/scheduled environment. `--dry-run` forces a no-write run regardless.
WRITE_SAP=false
WRITE_SUMMARY=false
WRITE_EVIDENCE=false      # per-comparison audit trail -> evidence container (append-only)

# ── Triage / explanation agent (advisory LLM layer — see explaination_agent.md) ──
# OFF by default: deterministic pipeline runs unchanged. Turn on only after the Azure
# deployment below is confirmed working AND the output is going to real users.
TRIAGE_ENABLED=false

# ── Azure OpenAI (DEWA company tenant) ───────────────────────────────────────
# LLM_PROVIDER MUST be 'azure' — this is the switch; filling the keys alone does nothing.
LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=              # https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=                   # resource key from the Azure portal
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# TRIAGE_MODEL = the Azure DEPLOYMENT name (Azure Portal -> your OpenAI resource ->
# Model deployments), NOT the model name like "gpt-4o-mini". Model must support structured
# outputs (gpt-4o / gpt-4o-mini 2024-08-06+). Wrong name -> DeploymentNotFound -> falls back
# to deterministic (never crashes). Use a DEWA-approved in-tenant deployment before production.
TRIAGE_MODEL=                      # <your-azure-deployment-name>
